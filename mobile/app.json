{
  "expo": {
    "name": "Attune",
    "slug": "attune",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "attune",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0a1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.attuneai.app",
      "infoPlist": {
        "NSContactsUsageDescription": "Allow Attune to access your contacts to help manage your relationship circle.",
        "NSMicrophoneUsageDescription": "Attune needs microphone access for voice input in Quick Talk.",
        "NSSpeechRecognitionUsageDescription": "Attune uses speech recognition to understand your voice input.",
        "NSFaceIDUsageDescription": "Allow Attune to use Face ID to securely access your account.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0a1a"
      },
      "package": "com.attuneai.app",
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Attune to access your contacts to help manage your relationship circle."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Attune to use Face ID to securely access your account."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#8B5CF6"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "9aed06e6-2412-4b7e-84c6-1303c1f2d3e5"
      }
    }
  }
}
