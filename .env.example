# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Claude AI Configuration (for Supabase Edge Functions)
# Set this as a secret in Supabase: supabase secrets set ANTHROPIC_API_KEY=your-key-here
# Get your API key from: https://console.anthropic.com/settings/keys
# Note: This is NOT a VITE_ variable - it's stored securely in Supabase secrets
